{
  "name": "@launchterminal/core",
  "version": "2.4.0",
  "description": "The open-source launchpad for deploying your own OpenClaw AI bot",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.mjs",
      "require": "./dist/plugins/index.js"
    },
    "./adapters": {
      "import": "./dist/adapters/index.mjs",
      "require": "./dist/adapters/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:full": "docker-compose up -d postgres redis && tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "docker:build": "docker build -t launchterminal:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env launchterminal:latest",
    "prepare": "husky install",
    "release": "changeset publish",
    "clean": "rimraf dist .turbo node_modules/.cache"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.1",
    "@grpc/proto-loader": "^0.7.12",
    "@openclaw/sdk": "^3.2.0",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.43.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.49.0",
    "@opentelemetry/sdk-node": "^0.49.0",
    "@sentry/node": "^7.100.0",
    "commander": "^12.0.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.29.3",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "nanoid": "^5.0.4",
    "pg": "^8.11.3",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.0",
    "slack-bolt": "^3.17.1",
    "telegraf": "^4.15.3",
    "ws": "^8.16.0",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@playwright/test": "^1.41.2",
    "@types/node": "^20.11.10",
    "@types/pg": "^8.10.9",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitest/coverage-v8": "^1.2.2",
    "drizzle-kit": "^0.20.14",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.0.7",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "testcontainers": "^10.4.0",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchterminal/launchterminal.git"
  },
  "keywords": [
    "openclaw",
    "ai",
    "bot",
    "chatbot",
    "discord",
    "slack",
    "telegram",
    "open-source",
    "self-hosted",
    "plugins"
  ],
  "author": "LaunchTerminal Contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/launchterminal/launchterminal/issues"
  },
  "homepage": "https://launchterminal.dev",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
