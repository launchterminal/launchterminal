# ============================================================
# LaunchTerminal Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Core
NODE_ENV=development
PORT=3000
WS_PORT=3001
LOG_LEVEL=info

# OpenClaw API
OPENCLAW_API_KEY=sk-claw-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENCLAW_ORG_ID=org-xxxxxxxxxxxx

# Database (PostgreSQL)
DATABASE_URL=postgresql://launchterminal:password@localhost:5432/launchterminal?sslmode=disable

# Cache (Redis)
REDIS_URL=redis://localhost:6379

# Encryption (256-bit key, auto-generated if not set)
ENCRYPTION_KEY=

# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Slack
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxx

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_ENDPOINT=http://localhost:4318
POSTHOG_API_KEY=

# Feature Flags
ENABLE_GRPC=false
ENABLE_VOICE=false
ENABLE_EXPERIMENTAL_PLUGINS=false
